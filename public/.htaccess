<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Prevent rewriting for static assets (e.g., JS, CSS, images)
    RewriteCond %{REQUEST_URI} !\.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot|map)$ [NC]
    # Handle requests for /designer-tool/ and its subpaths
    RewriteCond %{REQUEST_URI} ^/designer-tool(/.*)?$ [NC]
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ /designer-tool/index.html [L]

    # Existing WordPress rewrite rules (leave these intact)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule . /index.php [L]
</IfModule>