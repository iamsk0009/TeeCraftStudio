# Firebase Configuration
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-firebase-auth-domain
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-firebase-storage-bucket
VITE_FIREBASE_MESSAGING_SENDER_ID=your-firebase-messaging-sender-id
VITE_FIREBASE_APP_ID=your-firebase-app-id

# WooCommerce Configuration
VITE_WOOCOMMERCE_URL=https://your-woocommerce-store.com
VITE_WC_CONSUMER_KEY=your-woocommerce-consumer-key
VITE_WC_CONSUMER_SECRET=your-woocommerce-consumer-secret

# Gemini AI Configuration (Required for AI design generation)
# Get your API key from: https://makersuite.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here